@model JwtAuthApp.ViewModels.AuditDetailsViewModel
@using JwtAuthApp.ViewModels
@using System.Text.Json

@{
    ViewData["Title"] = "Детали аудита";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Детали аудита</h2>
    <a asp-action="Index" class="btn btn-primary">Назад к списку</a>
</div>

@if (Model.Type == AuditLogType.Action && Model.Log != null)
{
    var log = Model.Log;
    <div class="card">
        <div class="card-header">
            <span class="badge bg-info me-2">Действие</span>
            <strong>@log.Action</strong>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID записи</dt>
                <dd class="col-sm-9">@log.Id</dd>

                <dt class="col-sm-3">Время</dt>
                <dd class="col-sm-9">@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss.fff")</dd>

                <dt class="col-sm-3">Пользователь</dt>
                <dd class="col-sm-9">@log.UserName (ID: @(log.UserId?.ToString() ?? "—"))</dd>

                <dt class="col-sm-3">HTTP метод</dt>
                <dd class="col-sm-9">@log.HttpMethod</dd>

                <dt class="col-sm-3">URL</dt>
                <dd class="col-sm-9">@log.Url</dd>

                <dt class="col-sm-3">IP адрес</dt>
                <dd class="col-sm-9">@log.IpAddress</dd>

                <dt class="col-sm-3">User Agent</dt>
                <dd class="col-sm-9"><small>@log.UserAgent</small></dd>

                <dt class="col-sm-3">Успешно</dt>
                <dd class="col-sm-9">
                    @if (log.IsSuccess == true)
                    {
                        <span class="badge bg-success">OK</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Ошибка</span>
                    }
                </dd>

                <dt class="col-sm-3">Время выполнения</dt>
                <dd class="col-sm-9">@log.ExecutionTimeMs мс</dd>

                @if (log.TargetId.HasValue)
                {
                    <dt class="col-sm-3">TargetId</dt>
                    <dd class="col-sm-9">@log.TargetId</dd>
                }

                <dt class="col-sm-3">Details</dt>
                <dd class="col-sm-9"><pre class="bg-light p-2 mb-0">@log.Details</pre></dd>
            </dl>
        </div>
    </div>
}
else if (Model.Type == AuditLogType.Change && Model.Log != null)
{
    var log = Model.Log;
    <div class="card mb-3">
        <div class="card-header">
            <span class="badge bg-warning text-dark me-2">Изменение</span>
            <strong>@log.EntityType</strong>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID записи</dt>
                <dd class="col-sm-9">@log.Id</dd>

                <dt class="col-sm-3">Время</dt>
                <dd class="col-sm-9">@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss.fff")</dd>

                <dt class="col-sm-3">Пользователь</dt>
                <dd class="col-sm-9">@((log.UserName ?? "System")) @if (log.UserId.HasValue) { <span class="text-muted">(ID: @log.UserId)</span> }</dd>

                <dt class="col-sm-3">Сущность</dt>
                <dd class="col-sm-9">@log.EntityType</dd>

                <dt class="col-sm-3">EntityId</dt>
                <dd class="col-sm-9">@((log.EntityId?.ToString()) ?? "—")</dd>

                <dt class="col-sm-3">Тип изменения</dt>
                <dd class="col-sm-9">@log.ChangeType</dd>
            </dl>
        </div>
    </div>

    @if (log.ChangeType == "Added" && !string.IsNullOrEmpty(log.NewValues))
    {
        <div class="card mb-3">
            <div class="card-header bg-success text-white"><strong>Новые данные</strong></div>
            <div class="card-body">
                @{
                    var newData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.NewValues);
                }
                @if (newData != null)
                {
                    <table class="table table-sm table-striped mb-0">
                        <thead><tr><th>Поле</th><th>Значение</th></tr></thead>
                        <tbody>
                        @foreach (var item in newData)
                        {
                            <tr><td><strong>@item.Key</strong></td><td>@item.Value?.ToString()</td></tr>
                        }
                        </tbody>
                    </table>
                }
                else
                {
                    <pre class="bg-light p-3 mb-0">@log.NewValues</pre>
                }
            </div>
        </div>
    }

    @if (log.ChangeType == "Deleted" && !string.IsNullOrEmpty(log.OriginalValues))
    {
        <div class="card mb-3">
            <div class="card-header bg-danger text-white"><strong>Удалённые данные</strong></div>
            <div class="card-body">
                @{
                    var originalData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.OriginalValues);
                }
                @if (originalData != null)
                {
                    <table class="table table-sm table-striped mb-0">
                        <thead><tr><th>Поле</th><th>Значение</th></tr></thead>
                        <tbody>
                        @foreach (var item in originalData)
                        {
                            <tr><td><strong>@item.Key</strong></td><td>@item.Value?.ToString()</td></tr>
                        }
                        </tbody>
                    </table>
                }
                else
                {
                    <pre class="bg-light p-3 mb-0">@log.OriginalValues</pre>
                }
            </div>
        </div>
    }

    @if (log.ChangeType == "Modified")
    {
        @if (!string.IsNullOrEmpty(log.ChangedProperties))
        {
            <div class="card mb-3">
                <div class="card-header bg-warning"><strong>Изменённые поля</strong></div>
                <div class="card-body">
                    @{
                        var changes = JsonSerializer.Deserialize<List<JsonElement>>(log.ChangedProperties);
                    }
                    @if (changes != null && changes.Any())
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead><tr><th>Поле</th><th>Старое</th><th>Новое</th></tr></thead>
                            <tbody>
                            @foreach (var change in changes)
                            {
                                <tr>
                                    <td><strong>@change.GetProperty("Property").GetString()</strong></td>
                                    <td class="text-danger">@change.GetProperty("OldValue").GetString()</td>
                                    <td class="text-success">@change.GetProperty("NewValue").GetString()</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white"><strong>До</strong></div>
                    <div class="card-body">
                        @{
                            var originalData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.OriginalValues ?? "{}");
                        }
                        @if (originalData != null && originalData.Any())
                        {
                            <table class="table table-sm table-striped mb-0">
                                <thead><tr><th>Поле</th><th>Значение</th></tr></thead>
                                <tbody>
                                @foreach (var item in originalData)
                                {
                                    <tr><td><strong>@item.Key</strong></td><td>@item.Value?.ToString()</td></tr>
                                }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-muted">Нет данных</div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header bg-info text-white"><strong>После</strong></div>
                    <div class="card-body">
                        @{
                            var newData = JsonSerializer.Deserialize<Dictionary<string, object>>(log.NewValues ?? "{}");
                        }
                        @if (newData != null && newData.Any())
                        {
                            <table class="table table-sm table-striped mb-0">
                                <thead><tr><th>Поле</th><th>Значение</th></tr></thead>
                                <tbody>
                                @foreach (var item in newData)
                                {
                                    <tr><td><strong>@item.Key</strong></td><td>@item.Value?.ToString()</td></tr>
                                }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-muted">Нет данных</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-warning">Запись не найдена</div>
}

