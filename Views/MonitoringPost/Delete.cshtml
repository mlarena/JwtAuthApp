@model JwtAuthApp.Models.MonitoringPost

@{
    ViewData["Title"] = "Delete Post";
}

<h2>Delete Post</h2>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this post?</h4>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
            <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Description) ? "No description" : Model.Description)</dd>

            <dt class="col-sm-3">Coordinates</dt>
            <dd class="col-sm-9">
                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                {
                    <span>@Model.Latitude°, @Model.Longitude°</span>
                }
                else
                {
                    <span class="text-muted">No coordinates</span>
                }
            </dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsMobile)</dt>
            <dd class="col-sm-9">@(Model.IsMobile ? "Yes" : "No")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsActive)</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
        </dl>
    </div>
    <div class="card-footer">
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>