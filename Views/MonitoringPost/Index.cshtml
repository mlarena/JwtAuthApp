@model IEnumerable<JwtAuthApp.Models.MonitoringPost>

@{
    ViewData["Title"] = "Monitoring Posts";
}

<h2>Monitoring Posts</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Post</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>Coordinates</th>
            <th>@Html.DisplayNameFor(model => model.IsMobile)</th>
            <th>@Html.DisplayNameFor(model => model.IsActive)</th>
            <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.IsActive ? "" : "table-secondary")">
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td>
                    @if (item.Latitude.HasValue && item.Longitude.HasValue)
                    {
                        <span>@item.Latitude°, @item.Longitude°</span>
                    }
                    else
                    {
                        <span class="text-muted">No coordinates</span>
                    }
                </td>
                <td>
                    @if (item.IsMobile)
                    {
                        <span class="badge bg-info">Mobile</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Fixed</span>
                    }
                </td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </td>
                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-secondary" : "btn-success")">
                                @(item.IsActive ? "Deactivate" : "Activate")
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>