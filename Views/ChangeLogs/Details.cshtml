@model JwtAuthApp.Models.EntityChangeLog
@using System.Text.Json

@{
    ViewData["Title"] = "Детали изменения";
}

<div class="container">
    <h2>Детали изменения</h2>
    
    <div class="card mb-3">
        <div class="card-header">
            <strong>Основная информация</strong>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID записи:</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Время:</dt>
                <dd class="col-sm-9">@Model.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss.fff")</dd>

                <dt class="col-sm-3">Пользователь:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.UserName))
                    {
                        <span>@Model.UserName</span>
                        if (Model.UserId.HasValue)
                        {
                            <span class="text-muted"> (ID: @Model.UserId)</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Система</span>
                    }
                </dd>

                <dt class="col-sm-3">Тип сущности:</dt>
                <dd class="col-sm-9">@Model.EntityType</dd>

                <dt class="col-sm-3">ID сущности:</dt>
                <dd class="col-sm-9">@(Model.EntityId?.ToString() ?? "—")</dd>

                <dt class="col-sm-3">Тип изменения:</dt>
                <dd class="col-sm-9">
                    @if (Model.ChangeType == "Added")
                    {
                        <span class="badge bg-success">Добавление</span>
                    }
                    else if (Model.ChangeType == "Modified")
                    {
                        <span class="badge bg-warning">Изменение</span>
                    }
                    else if (Model.ChangeType == "Deleted")
                    {
                        <span class="badge bg-danger">Удаление</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.ChangeType</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    @if (Model.ChangeType == "Added" && !string.IsNullOrEmpty(Model.NewValues))
    {
        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <strong>Данные новой записи</strong>
            </div>
            <div class="card-body">
                @{
                    var newData = JsonSerializer.Deserialize<Dictionary<string, object>>(Model.NewValues);
                }
                @if (newData != null)
                {
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Поле</th>
                                <th>Значение</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in newData)
                            {
                                <tr>
                                    <td><strong>@item.Key</strong></td>
                                    <td>@item.Value?.ToString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <pre class="bg-light p-3">@Model.NewValues</pre>
                }
            </div>
        </div>
    }

    @if (Model.ChangeType == "Deleted" && !string.IsNullOrEmpty(Model.OriginalValues))
    {
        <div class="card mb-3">
            <div class="card-header bg-danger text-white">
                <strong>Удаленные данные</strong>
            </div>
            <div class="card-body">
                @{
                    var originalData = JsonSerializer.Deserialize<Dictionary<string, object>>(Model.OriginalValues);
                }
                @if (originalData != null)
                {
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Поле</th>
                                <th>Значение</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in originalData)
                            {
                                <tr>
                                    <td><strong>@item.Key</strong></td>
                                    <td>@item.Value?.ToString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <pre class="bg-light p-3">@Model.OriginalValues</pre>
                }
            </div>
        </div>
    }

    @if (Model.ChangeType == "Modified")
    {
        if (!string.IsNullOrEmpty(Model.ChangedProperties))
        {
            <div class="card mb-3">
                <div class="card-header bg-warning">
                    <strong>Измененные поля</strong>
                </div>
                <div class="card-body">
                    @{
                        var changes = JsonSerializer.Deserialize<List<JsonElement>>(Model.ChangedProperties);
                    }
                    @if (changes != null && changes.Any())
                    {
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Поле</th>
                                    <th>Старое значение</th>
                                    <th>Новое значение</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var change in changes)
                                {
                                    <tr>
                                        <td><strong>@change.GetProperty("Property").GetString()</strong></td>
                                        <td class="text-danger">@change.GetProperty("OldValue").GetString()</td>
                                        <td class="text-success">@change.GetProperty("NewValue").GetString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">
                        <strong>До изменения</strong>
                    </div>
                    <div class="card-body">
                        @{
                            var originalData = JsonSerializer.Deserialize<Dictionary<string, object>>(Model.OriginalValues ?? "{}");
                        }
                        @if (originalData != null && originalData.Any())
                        {
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>Поле</th>
                                        <th>Значение</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in originalData)
                                    {
                                        <tr>
                                            <td><strong>@item.Key</strong></td>
                                            <td>@item.Value?.ToString()</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Нет данных</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <strong>После изменения</strong>
                    </div>
                    <div class="card-body">
                        @{
                            var newData = JsonSerializer.Deserialize<Dictionary<string, object>>(Model.NewValues ?? "{}");
                        }
                        @if (newData != null && newData.Any())
                        {
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>Поле</th>
                                        <th>Значение</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in newData)
                                    {
                                        <tr>
                                            <td><strong>@item.Key</strong></td>
                                            <td>@item.Value?.ToString()</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">Нет данных</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Назад к списку
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // Добавляем иконки Bootstrap Icons если их нет
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css';
        document.head.appendChild(link);
    </script>
}