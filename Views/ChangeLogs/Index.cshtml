@model IEnumerable<JwtAuthApp.Models.EntityChangeLog>

@{
    ViewData["Title"] = "Журнал изменений данных";
}

<h2>Журнал изменений данных</h2>

<!-- Форма фильтрации -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Тип сущности</label>
                <select name="entityType" class="form-select">
                    <option value="">Все</option>
                    @foreach (var type in ViewBag.EntityTypes ?? new List<string>())
                    {
                        if (ViewBag.EntityType == type)
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </div>
            
            <div class="col-md-3">
                <label class="form-label">Тип изменения</label>
                <select name="changeType" class="form-select">
                    <option value="">Все</option>
                    @foreach (var type in ViewBag.ChangeTypes ?? new List<string>())
                    {
                        if (ViewBag.ChangeType == type)
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </div>
            
            <div class="col-md-2">
                <label class="form-label">С даты</label>
                <input type="datetime-local" name="from" class="form-control" value="@(ViewBag.From?.ToString("yyyy-MM-ddTHH:mm"))" />
            </div>
            
            <div class="col-md-2">
                <label class="form-label">По дату</label>
                <input type="datetime-local" name="to" class="form-control" value="@(ViewBag.To?.ToString("yyyy-MM-ddTHH:mm"))" />
            </div>
            
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">Применить</button>
            </div>
        </form>
    </div>
</div>

<!-- Пагинация -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        Страница @ViewBag.CurrentPage из @ViewBag.TotalPages (всего: @ViewBag.TotalItems)
    </div>
    <div>
        @if (ViewBag.CurrentPage > 1)
        {
            <a href="@Url.Action("Index", new { 
                page = ViewBag.CurrentPage - 1, 
                entityType = ViewBag.EntityType, 
                changeType = ViewBag.ChangeType,
                from = ViewBag.From, 
                to = ViewBag.To 
            })" class="btn btn-sm btn-outline-primary">Предыдущая</a>
        }
        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <a href="@Url.Action("Index", new { 
                page = ViewBag.CurrentPage + 1, 
                entityType = ViewBag.EntityType, 
                changeType = ViewBag.ChangeType,
                from = ViewBag.From, 
                to = ViewBag.To 
            })" class="btn btn-sm btn-outline-primary">Следующая</a>
        }
    </div>
</div>

<!-- Таблица с изменениями -->
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Время</th>
                <th>Пользователь</th>
                <th>Сущность</th>
                <th>ID</th>
                <th>Тип изменения</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                    <td>@(log.UserName ?? "Система")</td>
                    <td>@log.EntityType</td>
                    <td>@(log.EntityId?.ToString() ?? "—")</td>
                    <td>
                        @if (log.ChangeType == "Added")
                        {
                            <span class="badge bg-success">Добавление</span>
                        }
                        else if (log.ChangeType == "Modified")
                        {
                            <span class="badge bg-warning">Изменение</span>
                        }
                        else if (log.ChangeType == "Deleted")
                        {
                            <span class="badge bg-danger">Удаление</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@log.ChangeType</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@log.Id" class="btn btn-sm btn-info">
                            Детали
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Записи не найдены</div>
}