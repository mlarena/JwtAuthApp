@model JwtAuthApp.Models.UserActionLog

@{
    ViewData["Title"] = "Детали действия";
}

<h2>Детали действия</h2>

<div class="card">
    <div class="card-header">
        <strong>@Model.Action</strong>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">ID записи:</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Пользователь:</dt>
            <dd class="col-sm-9">@Model.UserName (ID: @Model.UserId)</dd>

            <dt class="col-sm-3">Действие:</dt>
            <dd class="col-sm-9">@Model.Action</dd>

            <dt class="col-sm-3">Детали:</dt>
            <dd class="col-sm-9">@Model.Details</dd>

            @if (Model.TargetId.HasValue)
            {
                <dt class="col-sm-3">ID цели:</dt>
                <dd class="col-sm-9">@Model.TargetId</dd>
            }

            <dt class="col-sm-3">HTTP метод:</dt>
            <dd class="col-sm-9">@Model.HttpMethod</dd>

            <dt class="col-sm-3">URL:</dt>
            <dd class="col-sm-9">@Model.Url</dd>

            <dt class="col-sm-3">IP адрес:</dt>
            <dd class="col-sm-9">@Model.IpAddress</dd>

            <dt class="col-sm-3">User Agent:</dt>
            <dd class="col-sm-9"><small>@Model.UserAgent</small></dd>

            <dt class="col-sm-3">Время:</dt>
            <dd class="col-sm-9">@Model.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss.fff")</dd>

            <dt class="col-sm-3">Статус:</dt>
            <dd class="col-sm-9">
                @if (Model.IsSuccess)
                {
                    <span class="badge bg-success">Успешно</span>
                }
                else
                {
                    <span class="badge bg-danger">Ошибка</span>
                }
            </dd>

            <dt class="col-sm-3">Время выполнения:</dt>
            <dd class="col-sm-9">@Model.ExecutionTimeMs мс</dd>
        </dl>
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-primary">Назад к списку</a>
    </div>
</div>